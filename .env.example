# ─────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (.env)
# Copy this file to .env and fill in your local/dev values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────

# Supabase — local dev (supabase start) or dev project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_default_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# API (Express scraping server)
API_PORT=3001
JWT_SECRET=your_jwt_secret_min_32_chars
AES_KEY=your_aes_key_exactly_32_chars__
REGISTER_SECRET=admin_registration_secret
CORS_ORIGIN=http://localhost:3000

# Bright Data Scraping Browser
BRIGHT_DATA_WSS=wss://brd-customer-<ID>:<PASS>@brd.superproxy.io:9222
BRIGHT_DATA_ZONE=scraping_browser1

# Session encryption (must be exactly 32 chars)
APP_SECRET=your_app_secret_exactly_32chars_

# Next.js (public vars)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_default_key
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────
# STAGING ENVIRONMENT
# Set these in GitHub → Settings → Secrets → Actions
# and in your staging hosting provider (e.g. Vercel/Railway)
# ─────────────────────────────────────────────────────────

# SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token   # shared across envs
# STAGING_SUPABASE_PROJECT_ID=your_staging_project_ref        # e.g. abcdefghijklmnop
# STAGING_SUPABASE_DB_PASSWORD=your_staging_db_password

# Staging app vars (set on hosting platform, not here)
# SUPABASE_URL=https://your-staging-project.supabase.co
# SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_staging_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key
# NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_staging_anon_key

# ─────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT
# Set these in GitHub → Settings → Secrets → Actions
# and in your production hosting provider
# ─────────────────────────────────────────────────────────

# SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token   # shared across envs
# PROD_SUPABASE_PROJECT_ID=your_production_project_ref        # e.g. zyxwvutsrqponmlk
# PROD_SUPABASE_DB_PASSWORD=your_production_db_password

# Production app vars (set on hosting platform, not here)
# SUPABASE_URL=https://your-production-project.supabase.co
# SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_production_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key
# NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_production_anon_key
